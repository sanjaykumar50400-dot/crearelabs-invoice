# ─── Copy this file to .env.local for local development ───────────────────────
# ─── Add ALL of these in Vercel → Settings → Environment Variables ────────────


# ── Vercel KV (Persistent Database) ──────────────────────────────────────────
# After adding Vercel KV storage (free), Vercel auto-fills these 3 variables.
# You don't need to set them manually — just add KV storage in Vercel dashboard.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=


# ── Resend (Email) ────────────────────────────────────────────────────────────
# Sign up free at https://resend.com
# Dashboard → API Keys → Create API Key → copy it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" email — MUST be from a domain you verify in Resend.
# Option A: Use Resend's free shared domain (works instantly, no setup):
#   RESEND_FROM_EMAIL=onboarding@resend.dev
# Option B: Use your own domain (looks professional):
#   Add your domain in Resend → Domains → verify DNS → use invoices@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev


# ── Fast2SMS (OTP via SMS) ────────────────────────────────────────────────────
# Sign up free at https://www.fast2sms.com
# Dashboard → Dev API → copy your API key
# Without this, OTP will be shown on screen (fallback mode — still works)
FAST2SMS_API_KEY=your_fast2sms_api_key_here


# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_PHONE=+919540117458
ADMIN_PASSWORD=Sanjay0911@95


# ── UPI Payment ───────────────────────────────────────────────────────────────
UPI_ID=crearelabs@ptaxis
UPI_NAME=Crearelabs


# ── App URL ───────────────────────────────────────────────────────────────────
# Set this AFTER first Vercel deploy, then redeploy once.
# Example: https://crearelabs-invoice.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
