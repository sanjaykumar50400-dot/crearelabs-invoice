# ─── Copy this to .env.local for local development ────────────────────────────
# ─── Add ALL of these in Vercel → Settings → Environment Variables ─────────────


# ── Upstash Redis (Database) ──────────────────────────────────────────────────
# These are AUTO-ADDED by Vercel when you install Upstash from Marketplace.
# You do NOT need to manually set these — just install Upstash in Vercel.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx


# ── Resend (Email Sending) ────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Use this "from" email — works instantly, no domain setup needed:
RESEND_FROM_EMAIL=onboarding@resend.dev


# ── Fast2SMS (OTP via SMS) ────────────────────────────────────────────────────
# Sign up free at https://fast2sms.com → Dev API → copy key
# Optional — without it, OTP is shown on screen (fallback mode)
FAST2SMS_API_KEY=your_fast2sms_key_here


# ── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_PHONE=+919540117458
ADMIN_PASSWORD=Sanjay0911@95


# ── UPI Payment ───────────────────────────────────────────────────────────────
UPI_ID=crearelabs@ptaxis
UPI_NAME=Crearelabs


# ── App URL (set after first Vercel deploy) ───────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
